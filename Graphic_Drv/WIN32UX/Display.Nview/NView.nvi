			<deleteRegistry keyName="HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\nview" valueName="TypesSupported"/>
			<deleteRegistry keyName="HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\nview" valueName="EventMessageFile"/>
		</standard>
		<standard phase="removeNviewSettingsInfo" onError="ignore" when="uninstall" condition="!KeepSettings">
			<deleteRegistryKeyTree keyName="${{NvidiaSoftwareKey}}\Global\nView"/>
			<deleteRegistryKeyTree keyName="${{NvidiaPerUserSoftwareKey}}\Global\nView"/>
			<deleteRegistryKeyTree keyName="${{NvidiaSoftwareKey}}\Global\nViewInstalled"/>
			<deleteRegistryKeyTree keyName="${{NvidiaPerUserSoftwareKey}}\Global\nViewInstalled"/>
			<deleteRegistryKey keyName="${{NvidiaSoftwareKey}}\Global"/>
			<deleteRegistryKey keyName="${{NvidiaSoftwareKey}}"/>
			<deleteRegistryKey keyName="${{NvidiaPerUserSoftwareKey}}\Global"/>
			<deleteRegistryKey keyName="${{NvidiaPerUserSoftwareKey}}"/>
		</standard>
		<standard phase="removeProfiles" when="uninstall" onError="ignore" condition="!KeepProfiles">
			<deleteDirectoryTree target="${{SharedWindowsDirectory}}\NView"/>
			<deleteDirectoryTree target="${{CommonAppData}}\NView_Profiles"/>
			<deleteDirectoryTree target="${{NViewProfileDir}}"/>
			<deleteDirectoryTree target="${{RoamingUserAppData}}\NVIDIA Corporation\NView"/>
		</standard>
		<custom phase="removeProfilesCustom" action="removeProfilesCustom" onError="ignore" when="uninstall" condition="!KeepProfiles"/>
		<if filter="NViewNext">
			<exe phase="nViewShutdown" when="uninstall" condition="nViewDllExists" name="${{SystemDirectory}}\rundll32.exe" dir="${{SystemDirectory}}" onError="ignore">
				<arg value="${{InstallLocation}}\nView.dll"/>
				<arg value=",nViewUnload" quote="none"/>
			</exe>
			<setPropertyIf phase="checkNViewDLLExists" boolProperty="nViewDllExists" value="true" when="uninstall">
				<file name="${{InstallLocation}}\nView.dll" check="exists"/>
			</setPropertyIf>
			<else>
				<custom phase="closeWindowsCustom" action="closeWindowsCustom" onError="ignore" when="uninstall"/>
				<custom phase="notifyUninstallation" action="notifyUninstallation" onError="ignore" when="uninstall" condition="!KeepSettings"/>
			</else>
		</if>
	</phases>
	<forms>
		<form name="PreUninstallNView" base="!PreUninstallTemplate" locale="0x0409">
			<control name="headText" style="header" x="15pt" y="63pt" width="408pt" height="90pt" text="${{KeepNViewElementsMessage}}"/>
			<control name="keepNViewProfiles" style="checkbox" x="15pt" y="110pt" text="${{NViewProfilesName}}" property="!KeepNViewProfiles" initSelect="true"/>
			<control name="keepNViewSettings" style="checkbox" x="15pt" y="125pt" text="${{NViewSettingsName}}" property="!KeepNViewSettings" initSelect="true"/>
		</form>
	</forms>
</nvi>
