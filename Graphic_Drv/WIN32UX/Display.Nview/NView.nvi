			<createDirectory target="${{CommonAppData}}\NVIDIA Corporation"/>
			<createDirectory target="${{CommonAppData}}\NVIDIA Corporation\NView"/>
		</standard>
		<custom phase="decideFilesToCopy" action="decideFilesToCopy" when="install"/>
		<standard phase="copyFiles">
