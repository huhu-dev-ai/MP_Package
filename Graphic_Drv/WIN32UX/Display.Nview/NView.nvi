		</setPropertyIf>
		<exe phase="nViewShutdown" when="install" condition="nViewDllExists" name="${{SystemDirectory}}\rundll32.exe" dir="${{SystemDirectory}}" onError="ignore">
			<arg value="${{InstallLocation}}\nView.dll"/>
			<arg value=",nViewUnload" quote="none"/>
		</exe>
		<custom phase="decideIfRebootRequired" action="decideIfRebootRequired" condition="nViewDllExists" when="install" onError="ignore"/>
		<standard phase="unregisterDLLs" onError="ignore" when="install">
			<unregisterDll target="nvshell.dll"/>
		</standard>
		<standard phase="registryCleanup" onError="ignore" when="uninstall">
			<deleteRegistry keyName="${{NvidiaSoftwareKey}}\Global\NVTweak" valueName="nViewShellIsRegistered"/>
			<deleteRegistryKey keyName="${{NvidiaSoftwareKey}}\Global\NVTweak"/>
			<deleteRegistryKey keyName="${{NvidiaSoftwareKey}}\Global"/>
			<deleteRegistryKey keyName="${{NvidiaSoftwareKey}}"/>
