					<copyFile target="nviewH64.dll"/>
					<copyFile target="nviewMain64.exe"/>
				</if>
			</if>
		</standard>
		<standard phase="copyNviewFiles" condition="!WillRequireReboot">
			<copyFile target="nvShell.dll"/>
			<copyFile target="nvwdmcpl.dll"/>
			<copyFile target="nwiz.exe"/>
			<copyFile target="nvAppBar.exe"/>
			<copyFile target="nView.dll"/>
			<copyFile target="nvwimg.dll"/>
			<if filter="amd64">
				<copyFile target="nView64.dll"/>
				<copyFile target="nvwimg64.dll"/>
			</if>
		</standard>
		<standard phase="copyNviewFilesWithLazyReboot" condition="WillRequireReboot">
			<copyFile target="nvShell.dll" inuse="afterRebootLazy"/>
			<copyFile target="nvwdmcpl.dll" inuse="afterRebootLazy"/>
			<copyFile target="nwiz.exe" inuse="afterRebootLazy"/>
			<copyFile target="nvAppBar.exe" inuse="afterRebootLazy"/>
			<copyFile target="nView.dll" inuse="afterRebootLazy"/>
			<copyFile target="nvwimg.dll" inuse="afterRebootLazy"/>
			<if filter="amd64">
				<copyFile target="nView64.dll" inuse="afterRebootLazy"/>
				<copyFile target="nvwimg64.dll" inuse="afterRebootLazy"/>
			</if>
		</standard>
		<standard phase="copyDefaultProfiles" when="install">
			<copyFile target="${{NViewProfileDir}}\default.tvp" source="default.tvp"/>
			<copyFile target="${{NViewProfileDir}}\advanced.tvp" source="advanced.tvp"/>
			<copyFile target="${{NViewProfileDir}}\cad.tvp" source="cad.tvp"/>
			<copyFile target="${{NViewProfileDir}}\dcc.tvp" source="dcc.tvp"/>
			<copyFile target="${{NViewProfileDir}}\finance.tvp" source="finance.tvp"/>
		</standard>
		<standard phase="registerTypeSupported">
			<addRegistry keyName="HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\nview" valueName="TypesSupported" type="REG_DWORD" value="31"/>
		</standard>
		<if filter="amd64">
			<standard phase="registerForEventingOn64">
				<addRegistry keyName="HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\nview" valueName="EventMessageFile" type="REG_SZ" value="${{InstallLocation}}\nview64.dll"/>
			</standard>
			<else>
				<standard phase="registerForEventingOn32">
					<addRegistry keyName="HKLM\SYSTEM\CurrentControlSet\Services\EventLog\Application\nview" valueName="EventMessageFile" type="REG_SZ" value="${{InstallLocation}}\nview.dll"/>
				</standard>
			</else>
		</if>
		<standard phase="registerDLLs">
			<registerDll target="nvshell.dll"/>
		</standard>
		<standard phase="clearRegistryEntry" when="install">
			<deleteRegistry keyName="HKLM\Software\Microsoft\Windows\CurrentVersion\Run" valueName="nwiz"/>
		</standard>
		<standard phase="registerControlPanel" when="install">
			<addRegistry keyName="HKLM\Software\Microsoft\Windows\CurrentVersion\Explorer\ControlPanel\NameSpace\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="" type="REG_SZ" value="${{nViewDisplayName}}"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="" value="${{nViewDisplayName}}" valueType="REG_SZ"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="{305CA226-D286-468E-B848-2B2E8E697B74} 2" value="0,1" valueType="REG_SZ"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}\DefaultIcon" valueName="" value="${{InstallLocation}}\nview.dll" valueType="REG_SZ"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}\Shell\Open\Command" valueName="" value="rundll32.exe &quot;${{InstallLocation}}\nvwdmcpl.dll&quot;, nViewMain" valueType="REG_SZ"/>
		</standard>
		<standard phase="setStringsUsingResDll" when="install" condition="ResourceDllExists">
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="LocalizedString" value="@${{InstallLocation}}\${{resourceDll}},-5000" valueType="REG_SZ"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="InfoTip" value="@${{InstallLocation}}\${{resourceDll}},-5001" valueType="REG_SZ"/>
		</standard>
		<standard phase="setStringsUsingStrings" when="install" condition="!ResourceDllExists">
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="LocalizedString" value="${{nViewDisplayName}}" valueType="REG_SZ"/>
			<addRegistry keyName="HKCR\CLSID\{002B9E07-2E10-438F-AF1E-40E6A96F1EE4}" valueName="InfoTip" value="Configure your ${{nViewDisplayName}} settings." valueType="REG_SZ"/>
		</standard>
		<if filter="amd64">
			<standard phase="registerWithNvMcTrayOn64">
				<addRegistry keyName="${{NvidiaSoftwareKey}}\Global\MediaCenterTray\nview.dll" valueName="FullPath" value="${{InstallLocation}}\nview64.dll" valueType="REG_SZ"/>
			</standard>
			<else>
				<standard phase="registerWithNvMcTrayOn32">
					<addRegistry keyName="${{NvidiaSoftwareKey}}\Global\MediaCenterTray\nview.dll" valueName="FullPath" value="${{InstallLocation}}\nview.dll" valueType="REG_SZ"/>
				</standard>
			</else>
		</if>
		<standard phase="DeleteOldShortcuts" onError="ignore">
			<deleteShortcutLink location="desktop" linkName="${{OldnViewShortCutName}}"/>
			<deleteShortcutLink location="startMenu" linkGroup="NVIDIA Corporation" linkName="${{OldnViewShortCutName}}"/>
			<deleteShortcutLink location="desktop" linkName="${{OldQuadroViewShortCutName}}"/>
			<deleteShortcutLink location="startMenu" linkGroup="NVIDIA Corporation" linkName="${{OldQuadroViewShortCutName}}"/>
		</standard>
		<standard phase="createDesktopShortcut" condition="CreateDesktopShortcut">
			<createShortcutLink location="desktop" targetPath="${{SystemDirectory}}\rundll32.exe" arguments="&quot;${{InstallLocation}}\nvwdmcpl.dll&quot;, nViewMain" linkName="${{nViewShortCutName}}" startIn="${{InstallLocation}}" runAsAdmin="false" iconPath="${{InstallLocation}}\nViewMain.exe"/>
		</standard>
		<standard phase="CreateStartMenuShortcut">
			<createShortcutGroup location="startMenu" linkGroup="NVIDIA Corporation"/>
			<createShortcutLink location="startMenu" targetPath="${{SystemDirectory}}\rundll32.exe" arguments="&quot;${{InstallLocation}}\nvwdmcpl.dll&quot;, nViewMain" linkGroup="NVIDIA Corporation" linkName="${{nViewShortCutName}}" startIn="${{InstallLocation}}" runAsAdmin="false" iconPath="${{InstallLocation}}\nViewMain.exe"/>
		</standard>
		<standard phase="AddEnvSettings" condition="AddPath">
			<addPath position="last" target="${{InstallLocation}}"/>
		</standard>
		<standard phase="addNViewInstalledKey" when="install">
			<addRegistry keyName="${{NvidiaSoftwareKey}}\Global\nViewInstalled" valueName="" type="REG_SZ" value=""/>
			<addRegistry keyName="${{NvidiaPerUserSoftwareKey}}\Global\nViewInstalled" valueName="" type="REG_SZ" value=""/>
		</standard>
		<standard phase="deleteCorruptedTaskFiles" when="install" onError="ignore">
			<deleteFile target="${{TasksPath}}\nWizard${{taskGuid}}"/>
		</standard>
		<standard phase="scheduleWizard">
			<scheduleTask action="create" taskName="nWizard" triggerType="logon" author="NVIDIA Corporation" description="NVIDIA NView Wizard" processPath="${{InstallLocation}}\nwiz.exe" arguments="/installquiet"/>
		</standard>
		<custom phase="hideOldARPEntry" action="hideOldARPEntry" when="install"/>
		<standard phase="addNvAppLaunchHostKey" when="installClose">
			<addRegistry keyName="HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\{B2FE1952-0186-46C3-BAEC-A80AA35AC5B8}_Display.NView" valueName="ProductHostExeCmd " type="REG_SZ" value="${{SystemDirectory}}\rundll32.exe &quot;${{InstallLocation}}\nvwdmcpl.dll&quot;, nViewMain"/>
		</standard>
		<standard phase="unregisterControlPanel" onError="ignore" when="uninstall">
