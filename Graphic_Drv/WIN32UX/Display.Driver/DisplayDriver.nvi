			<standard phase="deleteOlderDrsFiles" when="install" onError="ignore">
				<deleteFile target="${{NvidiaProgramFiles}}\DRS\dbInstaller.exe"/>
				<deleteFile target="${{NvidiaProgramFiles}}\DRS\nvdrsdb.bin"/>
				<deleteDirectoryTree target="${{NvidiaProgramFiles}}\DRS"/>
			</standard>
			<confirm phase="Confirm-install" when="install">
				<fileExists target="${{SystemDirectory}}\nvinfo.pb"/>
			</confirm>
			<confirm platform="x86" phase="Confirm-install" when="install">
				<fileExists target="${{SystemDirectory}}\nvapi.dll"/>
			</confirm>
			<confirm platform="amd64" phase="Confirm-install" when="install">
				<fileExists target="${{SystemDirectory}}\nvapi64.dll"/>
			</confirm>
			<if filter="!isDeclarative">
				<setPropertyIf phase="checkIfNvFBCPluginExists" boolProperty="NvFBCPluginExists" value="true" when="install">
					<file name="${{SubPackageDirectory}}\${{NvFBCPluginName}}" check="exists"/>
				</setPropertyIf>
				<standard phase="installNvFBCPlugins" condition="NvFBCPluginExists" when="install">
					<createDirectory target="${{NvFBCFolderPath}}"/>
					<copyFile source="${{NvFBCPluginName}}" target="${{NvFBCFolderPath}}\${{NvFBCPlugin}}"/>
					<createDirectory target="${{NvFBCSymLinkPath}}" source="${{NvFBCFolderPath}}" symLink="true"/>
				</standard>
				<standard phase="deleteOldNonOptioalNvToppsPlugin" when="install" onError="ignore">
					<renameFile source="${{NvToppsFolderPath}}\NvTopps.dll" target="${{NvToppsFolderPath}}\NvTopps.dll_"/>
					<deleteFile target="${{NvToppsFolderPath}}\NvTopps.dll_" waitForUnlock="${{pluginDeleteMaxTimeout}}"/>
				</standard>
				<standard phase="installNvToppsPlugins" when="install">
					<createDirectory target="${{NvToppsFolderPath}}"/>
					<copyFile source="nvtopps.db3" target="${{NvidiaProgramFiles}}\Display.NvContainer\nvtopps.db3"/>
					<copyFile source="nvgwls.exe" target="${{NvidiaProgramFiles}}\Display.NvContainer\nvgwls.exe"/>
					<copyFile source="dlsargs.xml" target="${{NvidiaProgramFiles}}\Display.NvContainer\dlsargs.xml"/>
					<copyFile source="dlsnetparams.csv" target="${{NvidiaProgramFiles}}\Display.NvContainer\dlsnetparams.csv"/>
					<copyFile source="${{NvToppsPlugin}}" target="${{NvToppsFolderPath}}\${{OptionalNvToppsPlugin}}"/>
					<createDirectory target="${{NvToppsSymLinkPath}}" source="${{NvToppsFolderPath}}" symLink="true"/>
				</standard>
				<setPropertyIf phase="checkIfVGPUFolderExists" boolProperty="VGPUFolderExists" value="true" when="install">
					<directory name="${{vGPUConfigPath}}" check="exists"/>
				</setPropertyIf>
				<standard phase="createJunctionPointforNvVGPUPlugin" condition="VGPUFolderExists" when="install">
					<createDirectory target="${{vGPUSymLinkPath}}" source="${{vGPUConfigPath}}" symLink="true"/>
				</standard>
				<if filter="minRS1">
					<standard phase="installWksServicePlugin">
						<copyFile source="${{WksServicePlugin}}" target="${{WksServicePluginFolderPath}}\${{WksServicePlugin}}"/>
						<createDirectory target="${{WksServiceSymLinkPath}}" source="${{WksServicePluginFolderPath}}" symLink="true"/>
					</standard>
					<standard phase="deleteOldwksServicePluginZero" when="install" onError="ignore">
						<renameFile source="${{WksServicePluginZeroFolderPath}}\wksServicePluginZero.dll" target="${{WksServicePluginZeroFolderPath}}\wksServicePluginZero.dll_"/>
						<deleteFile target="${{WksServicePluginZeroFolderPath}}\wksServicePluginZero.dll_" waitForUnlock="${{pluginDeleteMaxTimeout}}"/>
					</standard>
					<standard phase="installWksServicePluginZero">
						<copyFile source="${{WksServicePluginZero}}" target="${{WksServicePluginZeroFolderPath}}\${{WksServicePluginZero}}"/>
						<createDirectory target="${{WksServiceZeroSymLinkPath}}" source="${{WksServicePluginZeroFolderPath}}" symLink="true"/>
					</standard>
				</if>
			</if>
			<custom phase="checkDriverInterruptModeIssue" action="CheckDriverInterruptModeIssue" when="install" onError="ignore"/>
			<device phase="restartDevices" action="restart" condition="RmInterruptModeIssue" when="install" onError="ignore" fixedProgress="10" deviceProgress="150" autoTick="200">
				<inf name="*.inf"/>
				<hwid name="PCI\VEN_10DE¤"/>
			</device>
			<standard onError="ignore" phase="deleteOlderRASPluginData" when="install">
				<deleteDirectoryTree target="${{DisplayDriverRASSymLinkPath}}"/>
				<deleteFile target="${{DisplayDriverRASPluginPath}}\DisplayDriverRAS.dll" waitForUnlock="${{pluginDeleteMaxTimeout}}"/>
			</standard>
			<if filter="!isDeclarative">
				<standard phase="installDisplayDriverRASPlugin" condition="Feature.NvTelemetry" onError="ignore">
					<createDirectory target="${{DisplayDriverRASPluginPath}}"/>
					<copyFile target="${{DisplayDriverRASPluginPath}}\_DisplayDriverRAS.dll" source="DisplayDriverRAS.dll"/>
					<createDirectory target="${{DisplayDriverRASSymLinkPath}}" source="${{DisplayDriverRASPluginPath}}" symLink="true"/>
				</standard>
				<standard phase="installNvProfileUpdaterPlugin" when="install">
					<createDirectory target="${{NvProfileUpdaterDirPath}}"/>
					<copyFile target="${{NvProfileUpdaterDirPath}}\NvProfileUpdaterPlugin.dll" source="NvProfileUpdaterPlugin.dll"/>
				</standard>
				<standard phase="createNvProfileUpdaterJunctionPoint">
					<createDirectory target="${{NvProfileUpdaterSymLinkPath}}" source="${{NvProfileUpdaterDirPath}}" symLink="true"/>
				</standard>
				<if filter="minWin10">
					<standard phase="installGSTPlugin" onError="ignore">
						<createDirectory target="${{GSTPluginFolderPath}}"/>
						<copyFile target="${{GSTPluginFolderPath}}\${{GSTOptionalPlugin}}" source="${{GSTPlugin}}"/>
						<createDirectory target="${{GSTPluginSymLinkPath}}" source="${{GSTPluginFolderPath}}" symLink="true"/>
					</standard>
				</if>
			</if>
			<standard phase="copyLogo" condition="ICafeLogoSupported" when="install" onError="ignore">
				<copyFile target="${{NvidiaProgramFiles}}\Drs\logo.png" source="logo.png"/>
			</standard>
			<standard phase="removeOpenCLLegacyx86" when="install" onError="ignore" platform="x86">
				<deleteRegistry keyName="${{openCLRegKey}}" valueName="${{SysWowDirectory}}\nvopencl.dll"/>
				<deleteFile target="${{SysWowDirectory}}\nvopencl.dll"/>
			</standard>
			<standard phase="removeOpenCLLegacyx64" when="install" onError="ignore" platform="amd64">
				<deleteRegistry keyName="${{openCLRegKey}}" valueName="${{SystemDirectory}}\nvopencl.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvopencl.dll"/>
			</standard>
			<standard phase="removeDeprecatedFiles" when="install" onError="ignore" platform="amd64">
				<deleteFile target="${{SystemDirectory}}\nvinit.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvumdshim.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvinitx.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvumdshimx.dll"/>
				<deleteFile target="${{SysWowDirectory}}\nvinit.dll"/>
				<deleteFile target="${{SysWowDirectory}}\nvumdshim.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvoglshim32.dll"/>
				<deleteFile target="${{SystemDirectory}}\nvoglshim64.dll"/>
				<deleteFile target="${{SysWowDirectory}}\nvoglshim32.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\coprocmanager\nvdxgiwrapx.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\coprocmanager\nvdxgiwrap.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\coprocmanager\Nvd3d9wrapx.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\coprocmanager\Nvd3d9wrap.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\coprocmanager\nvdetx.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\coprocmanager\nvdet.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\coprocmanager\detoured.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\coprocmanager\detoured.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\nvgsync\detoured.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\nvgsync\nvdetx.dll"/>
				<deleteFile target="${{NvidiaProgramFiles}}\nvgsync\nvgsyncdetours.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\nvgsync\detoured.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\nvgsync\nvdet.dll"/>
				<deleteFile target="${{NvidiaProgramFilesX86}}\nvgsync\nvgsyncdetours.dll"/>
			</standard>
			<setPropertyIf phase="checkNVSMIPathExist" boolProperty="CheckNVSMIPathExist" value="true" when="install" onError="ignore">
				<directory name="${{NvidiaProgramFiles}}\NVSMI" check="exists"/>
			</setPropertyIf>
			<standard phase="addNvsmiToReg" when="install" condition="CheckNVSMIPathExist" onError="ignore">
				<addRegistry keyName="${{NvidiaSoftwareKey}}\Global\NVSMI" valueName="NVSMIPATH" type="REG_SZ" value="${{NvidiaProgramFiles}}\NVSMI"/>
			</standard>
			<setPropertyIf phase="checkIfGridTPLFileExists" boolProperty="GridTPLFileExists" value="true" onError="ignore">
				<file name="${{SubPackageDirectory}}\grid-third-party-licenses.txt" check="exists"/>
			</setPropertyIf>
			<standard phase="copyGridLicenseFile" condition="GridTPLFileExists" onError="ignore">
				<copyFile target="${{NvidiaProgramFiles}}\grid-third-party-licenses.txt" source="grid-third-party-licenses.txt"/>
			</standard>
			<setPropertyIf phase="checkIfGridProxyScriptExists" boolProperty="GridProxyScriptExists" value="true" onError="ignore" when="install">
				<file name="${{SubPackageDirectory}}\grid-proxy-credentials.ps1" check="exists"/>
			</setPropertyIf>
			<standard phase="copyGridProxyScript" condition="GridProxyScriptExists" onError="ignore" when="install">
				<copyFile target="${{GridProxySettingsFolderPath}}\grid-proxy-credentials.ps1" source="grid-proxy-credentials.ps1"/>
			</standard>
			<exe phase="deregisterOSCTool" onError="ignore" name="${{@DriverStoreLocation}}\NvOSC.exe" when="uninstall">
				<arg value="-deregister" quote="none"/>
			</exe>
			<custom phase="getDriverStoreLocation" action="GetDriverStoreLocationInProperty" when="uninstall" onError="ignore">
				<properties>
					<string name="PropertyName" value="DriverStoreLocation"/>
				</properties>
			</custom>
			<standard phase="deleteGridProxyScript" onError="ignore" when="uninstall">
				<deleteFile target="${{GridProxySettingsFolderPath}}\grid-proxy-credentials.ps1"/>
				<deleteDirectory target="${{GridProxySettingsFolderPath}}"/>
			</standard>
			<if filter="minWin8">
				<custom phase="SetRebootForWin8KFilter" action="SetRebootForWin8KFilter" when="install"/>
			</if>
			<custom phase="changeDisplayResolution" action="SetResolution" when="install"/>
			<custom phase="removeOldARPEntry" action="RemoveOldARPEntry" onError="ignore" when="install"/>
			<if filter="minVista">
				<custom phase="VulkanUninstall" action="uninstallVulkan" onError="ignore" when="install"/>
			</if>
			<custom phase="checkRemoveOptimusFilters" action="checkRemoveOptimusFilters" when="install" onError="ignore"/>
			<standard phase="removeOldOpenGLCache" when="install" onError="ignore">
				<deleteDirectoryTree target="${{RoamingUserAppData}}\NVIDIA\GLCache"/>
				<deleteDirectoryTree target="${{LocalUserAppData}}\NVIDIA\GLCache"/>
				<deleteDirectoryTree target="${{LocalUserAppData}}\..\Locallow\NVIDIA\GLCache"/>
			</standard>
			<if filter="!isDeclarative">
				<exe phase="containerInstall" when="install" name="NvContainerSetup.exe" progress="500" autotick="200" condition="Global:EnableTelemetry">
					<arg value="-n"/>
					<arg value="-s"/>
					<arg value="-enableTelemetry:true"/>
					<success value="0"/>
					<success value="1" rebootNeeded="true"/>
				</exe>
				<exe phase="containerInstall" when="install" name="NvContainerSetup.exe" progress="500" autotick="200" condition="!Global:EnableTelemetry">
					<arg value="-n"/>
					<arg value="-s"/>
					<arg value="-enableTelemetry:false"/>
					<success value="0"/>
					<success value="1" rebootNeeded="true"/>
				</exe>
			</if>
			<standard phase="deleteNvFBCx86" platform="x86" when="install" onError="ignore">
				<deleteDirectoryTree target="${{NvidiaProgramFilesX86}}\NvFBC"/>
			</standard>
			<standard onError="ignore" phase="startNVWMIService" when="installClose" condition="WasNVWMIRunning">
				<startService name="${{NVWMIServiceName}}" timeOut="${{StateTransitionMaxTime}}"/>
			</standard>
		</if>
		<if filter="!isDeclarative">
			<custom phase="updateCPLInstallPhaseApp" action="updateCPLInstallPhaseApp" when="install">
				<properties>
					<string name="CPLSearchPath" value="${{SubPackageDirectory}}"/>
				</properties>
			</custom>
			<custom phase="removeCPLInstallData" action="removeCPLInstallData" when="install"/>
			<exe phase="cplInstall" when="install" name="*cplsetup*.exe" progress="500" autoTick="200" condition="!SkipCPLInstall &amp;&amp; Global:EnableTelemetry">
				<arg value="-n"/>
				<arg value="-s"/>
				<arg value="-enableTelemetry:true"/>
				<arg value="Display.ControlPanel"/>
				<success value="0"/>
				<success value="1" rebootNeeded="true"/>
			</exe>
			<exe phase="cplInstall" when="install" name="*cplsetup*.exe" progress="500" autoTick="200" condition="!SkipCPLInstall &amp;&amp; !Global:EnableTelemetry">
				<arg value="-n"/>
				<arg value="-s"/>
				<arg value="-enableTelemetry:false"/>
				<arg value="Display.ControlPanel"/>
				<success value="0"/>
				<success value="1" rebootNeeded="true"/>
			</exe>
		</if>
		<if filter="!OEMPreloadApps">
			<if filter="!safeMode">
				<if filter="!isDeclarative">
					<standard phase="startDisplayContainerLocalSystem" when="install">
						<startService name="${{DisplayContainerServiceName}}" timeOut="${{StateTransitionMaxTime}}"/>
					</standard>
				</if>
			</if>
		</if>
		<exe phase="runCacheCleanupTool" name="${{NvidiaProgramFilesX86}}\NvInstallerUtil\NvInstallerUtil.exe" when="installClose" onError="ignore" condition="!Global:RebootRequired &amp;&amp; !Global:SilentInstall" flags="nowait,disassociate">
			<arg value="-s" quote="none"/>
		</exe>
		<custom phase="CheckDanglingDeviceRemoval" action="CheckDanglingDeviceRemoval" when="install" onError="ignore">
			<properties>
				<string name="PropertyToSetIfApplicable" value="IsNvModuleTrackerDeviceRemovalApplicable"/>
				<string name="hwid" value="ROOT\NVMODULETRACKER"/>
			</properties>
		</custom>
		<custom phase="CheckDanglingDeviceRemoval" action="CheckDanglingDeviceRemoval" when="install" onError="ignore">
			<properties>
				<string name="PropertyToSetIfApplicable" value="IsNvVHciDeviceRemovalApplicable"/>
				<string name="hwid" value="ROOT\NVVHCI"/>
			</properties>
		</custom>
		<device phase="removeNvModuleTrackerDevice" action="remove" when="install" condition="IsNvModuleTrackerDeviceRemovalApplicable" onError="ignore">
			<hwid name="ROOT\NVMODULETRACKER"/>
		</device>
		<device phase="removeNvVHciDevice" action="remove" when="install" condition="IsNvVHciDeviceRemovalApplicable" onError="ignore">
			<hwid name="ROOT\NVVHCI"/>
		</device>
	</phases>
</nvi>
